{
  "name": "accutheme-tw4",
  "version": "2026.04.12",
  "type": "module",
  "scripts": {
    "start": "npx @tailwindcss/cli -i ./src/tailwind/index.css -o ./dnn/Portals/_default/Skins/AccuTheme-Tw4/Skin.css --watch",
    "build": "npx @tailwindcss/cli --minify -i ./src/tailwind/index.css -o ./dnn/Portals/_default/Skins/AccuTheme-Tw4/Skin.css",
    "images": "rollup --config rollup.config.images.mjs",
    "prettier": "npx prettier --write .",
    "favicons": "pwsh -File ./ps/AccuTheme-Favicons.ps1",
    "accutheme": "pwsh -File ./ps/AccuTheme-Config.ps1",
    "updateDLLs": "robocopy \"A:\\dev\\dlls\" \"C:\\dev\\dlls\" /MIR /W:5 /R:2 /NJH /NDL",
    "cleanDLLs": "pwsh -Command \"Remove-Item -Path C:\\dev\\dlls -Recurse -Force; Copy-Item -Path A:\\dev\\dlls -Destination C:\\dev\\dlls -Recurse -Force\"",
    "postinstall": "npm run build",
    "install:nobuild": "npm install --ignore-scripts",
    "dotnet": "dotnet --info",
    "=== Note 20260123": "NX: AI-built /ps commands to upload to remote and ensure WinSCP is installed. Usage: npm run push:file -- path/to/file",
    "push:file": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./ps/Push-FileToRemote.ps1",
    "winscp:ensure": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./ps/Ensure-WinSCP.ps1",
    "=== Note 0": "nop - experiments, leftovers, etc",
    "start:tw4": "npx @tailwindcss/cli -i ./src/tailwind/index.css -o ./dnn/Portals/_default/Skins/AccuTheme-Tw4/AccuTheme-Tw4.css --watch",
    "build:tw4": "npx @tailwindcss/cli --minify -i ./src/tailwind/index.css -o ./dnn/Portals/_default/Skins/AccuTheme-Tw4/AccuTheme-Tw4.css",
    "=== Note 1 ===": "nop - things above work, things below... nope",
    "=== Note 1 ==-": "nop - things above work, things below... nope",
    "=== Note 1 =--": "nop - things above work, things below... nope",
    "dnn-package": "rollup --config rollup.config.dnn-package.js --mode production",
    "=== Note 2": "nop - things above are planned, but not working yet, things below are placeholders, ideas, experiments, leftovers, etc",
    "watch": "echo use 'npm start'",
    "test": "echo n/a",
    "start:js": "webpack --config webpack.config.skin.NavSite.js --mode development",
    "build:js": "webpack --config webpack.config.skin.NavSite.js --mode production",
    "build:not": "nop npm run build:css && npm run build:js",
    "clean": "nop rimraf dist",
    "end-of-scripts": "nop"
  },
